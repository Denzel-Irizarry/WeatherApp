@page "/weather"
@using WeatherApp.Models
@using WeatherApp.Services
@inject IWeatherForecastService ForecastService

<PageTitle>Weather Forecast</PageTitle>

<h1>Weather Forecast</h1>

<p>Check out the weather forecast for your location!</p>

<div class="mb-3">
    <label class="form-label" for="location">Location</label>
    <div class="input-group">
        <input id="location" class="form-control" @bind="location" @bind:event="oninput" placeholder="dixon ca " />
        <button class="btn btn-primary" @onclick="LoadForecastAsync" disabled="@isLoading">Get Forecast</button>
    </div>
    <div class="form-text">Accepts city names, ZIP codes, and latitude/longitude.</div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

@if (isLoading)
{
    <p><em>Loading forecast...</em></p>
}
else if (forecast is not null)
{
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h4 mb-2">Current Selection</h2>
            <p class="mb-1"><strong>Resolved location:</strong> @DisplayLocation()</p>
        </div>
    </div>

    @if (hourlyForecasts.Count > 0)
    {
        <h2 class="h4">Next 12 Hours</h2>
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Temp</th>
                    <th>Feels Like</th>
                    <th>Rain %</th>
                    <th>Humidity</th>
                    <th>Wind</th>
                    <th>Conditions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hour in hourlyForecasts)
                {
                    <tr>
                        <td>@hour.Time.ToLocalTime().ToString("ddd h tt")</td>
                        <td>@FormatNumber(hour.Temperature)@forecast.Units.Temperature</td>
                        <td>@FormatNumber(hour.TemperatureApparent)@forecast.Units.Temperature</td>
                        <td>@FormatNumber(hour.PrecipitationProbability)%</td>
                        <td>@FormatNumber(hour.Humidity)%</td>
                        <td>@FormatNumber(hour.WindSpeed) @forecast.Units.WindSpeed</td>
                        <td>
                            <img src="@GetWeatherIconPath(hour.WeatherCode, hour.Time)" alt="@hour.WeatherDescription" width="28" height="28" class="me-2" />
                            @hour.WeatherDescription
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (dailyForecasts.Count > 0)
    {
        <h2 class="h4 mt-4">Next 5 Days</h2>
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Low</th>
                    <th>High</th>
                    <th>Rain %</th>
                    <th>Wind</th>
                    <th>Conditions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var day in dailyForecasts)
                {
                    <tr>
                        <td>@day.Time.ToLocalTime().ToString("dddd")</td>
                        <td>@FormatNumber(day.TemperatureMin)@forecast.Units.Temperature</td>
                        <td>@FormatNumber(day.TemperatureMax)@forecast.Units.Temperature</td>
                        <td>@FormatNumber(day.PrecipitationProbability)%</td>
                        <td>@FormatNumber(day.WindSpeed) @forecast.Units.WindSpeed</td>
                        <td>
                            <img src="@GetWeatherIconPath(day.WeatherCode, day.Time)" alt="@day.WeatherDescription" width="32" height="32" class="me-2" />
                            @day.WeatherDescription
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <img src="/images/Powered_by_Tomorrow-Black.svg" alt="Powered by Tomorrow.io" style="height: 28px; width: auto;" />
    </div>
}

@code {
    private const string IconBasePath = "/icons/tomorrow";

    private WeatherForecastResult? forecast;
    private string location = "dixon ca";
    private string? errorMessage;
    private bool isLoading;

    private List<WeatherForecastPeriod> hourlyForecasts => forecast?.HourlyPeriods.Take(12).ToList() ?? [];
    private List<WeatherForecastPeriod> dailyForecasts => forecast?.DailyPeriods.Take(5).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadForecastAsync();
    }

    private async Task LoadForecastAsync()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            forecast = await ForecastService.GetForecastAsync(location.Trim());
        }
        catch (TomorrowIoApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private string DisplayLocation()
    {
        var resolved = forecast?.Location;
        if (resolved is null)
        {
            return location;
        }

        return $"{resolved.Name ?? location} ({resolved.Latitude:F4}, {resolved.Longitude:F4})";
    }

    private static string FormatNumber(decimal? value)
    {
        return value?.ToString("0.#") ?? "-";
    }

    private static string GetWeatherIconPath(int? weatherCode, DateTimeOffset time)
    {
        var iconName = weatherCode switch
        {
            1000 => IsNight(time) ? "clear_night" : "clear_day",
            1001 => "cloudy",
            1100 => IsNight(time) ? "mostly_clear_night" : "mostly_clear_day",
            1101 => IsNight(time) ? "partly_cloudy_night" : "partly_cloudy_day",
            1102 => "mostly_cloudy",
            2000 => "fog",
            2100 => "fog_light",
            4000 => "drizzle",
            4001 => "rain",
            4200 => "rain_light",
            4201 => "rain_heavy",
            5000 => "snow",
            5001 => "flurries",
            5100 => "snow_light",
            5101 => "snow_heavy",
            6000 => "freezing_drizzle",
            6001 => "freezing_rain",
            6200 => "freezing_rain_light",
            6201 => "freezing_rain_heavy",
            7000 => "ice_pellets",
            7101 => "ice_pellets_heavy",
            7102 => "ice_pellets_light",
            8000 => "tstorm",
            _ => "cloudy"
        };

        return $"{IconBasePath}/{iconName}.svg";
    }

    private static bool IsNight(DateTimeOffset time)
    {
        var localHour = time.ToLocalTime().Hour;
        return localHour < 6 || localHour >= 18;
    }
}

